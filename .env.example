# Copy to .env and fill in. .env is gitignored.

# Required — Meraki Dashboard API key
MERAKI_API_KEY=

# Optional — override the Meraki API base URL (default shown)
# MERAKI_BASE_URL=https://api.meraki.com/api/v1

# Required — Anthropic API key for the AI features
ANTHROPIC_API_KEY=

# Optional — container timezone (affects scheduled report timing + log timestamps)
# TZ=America/Chicago
