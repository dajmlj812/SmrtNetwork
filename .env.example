# Copy to .env and fill in. .env is gitignored.

# Required — Meraki Dashboard API key
MERAKI_API_KEY=

# Optional — override the Meraki API base URL (default shown)
# MERAKI_BASE_URL=https://api.meraki.com/api/v1

# Required — Anthropic API key for the AI features
ANTHROPIC_API_KEY=

# Optional — container timezone (affects scheduled report timing + log timestamps)
# TZ=America/Chicago

# Required ONLY for docker-compose.tunnel.yml — Cloudflare Tunnel connector token.
# Get it from the Cloudflare Zero Trust dashboard:
#   Networks → Tunnels → Create a tunnel → Cloudflared connector → copy the
#   long --token value (starts with eyJ, ~180+ characters).
# Not needed for the default docker-compose.yml deployment.
# CLOUDFLARE_TUNNEL_TOKEN=eyJ...
